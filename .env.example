# ============================================
# OA 系统 - Docker Compose 环境变量
# 复制此文件为 .env 并填入真实值
# WARNING: .env 绝不提交到 Git！
# ============================================

# MySQL 数据库
MYSQL_ROOT_PASSWORD=请修改为强密码
MYSQL_DATABASE=oa_system
MYSQL_PORT=3306

# JWT 密钥（请随机生成）
JWT_SECRET=请替换为随机密钥

# 服务端口映射
SERVER_PORT=3000
ADMIN_PORT=8082
DOMES_PORT=8081
