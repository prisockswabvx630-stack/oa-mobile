# ============================================
# OA Server 环境变量模板
# 复制此文件为 .env 并填入真实值
# WARNING: .env 文件绝不提交到 Git！
# ============================================

# 数据库连接（MySQL）
DATABASE_URL="mysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4"

# JWT 签名密钥（请使用随机生成的长字符串）
JWT_SECRET="请替换为随机生成的密钥"

# 服务端口（可选，默认 3000）
PORT=3000
